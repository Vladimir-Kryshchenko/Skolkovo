# Скопируйте в .env и при необходимости измените значения.

# PostgreSQL (реестр метаданных и БД админки)
POSTGRES_USER=skolkovo
POSTGRES_PASSWORD=skolkovo
POSTGRES_DB=skolkovo
POSTGRES_DSN=postgres://skolkovo:skolkovo@localhost:5432/skolkovo?sslmode=disable

# Qdrant (векторная БД)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=skolkovo_docs

# TEI (эмбеддинги multilingual-e5)
TEI_URL=http://localhost:8081
EMBEDDING_DIM=768

# Источник документов
SOURCE_URL=https://dochub.sk.ru/foundation/documents/

# Папка первоисточников
DOCS_DIR=./Документы_Сколково

# Хранилище метаданных: json | postgres
STORE_BACKEND=json
REGISTRY_PATH=./Документы_Сколково/Метаданные/реестр_документов.json

# Регламент парсинга
REPORT_DIR=./Аналитика/Отчеты/Отчеты_парсинга
SCRAPE_INTERVAL=6h

# Регламент парсинга (ограничители и периодичность)
SCRAPE_MAX_PAGES=200
SCRAPE_DELAY=3s

# Новости / RSS
NEWS_RSS_URL=https://sk.ru/news/rss/

# Уведомления об изменениях (POST JSON); пусто — выключено
NOTIFY_WEBHOOK=

# Headless-загрузчик файлов (обход WAF). Запускать из разрешённой сети/прокси.
CHROME_PATH=
PROXY_URL=
FETCH_LIMIT=0
FETCH_WAIT=7s

# MCP-сервер
MCP_ADDR=:8080
MCP_API_KEY=change-me-please
MCP_RATE_LIMIT_RPS=5

# Админка (если ADMIN_USER пуст — без авторизации)
ADMIN_ADDR=:8090
ADMIN_USER=
ADMIN_PASSWORD=
