QWEN_API_KEY=sk-ws-H.HLEIDR.ED70.MEQCIF82r_BLutmUDXe-2jp2YBfRmfC-TkE6JMhOEKGL_qbPAiAOZGqcrfXynKwj7xIvgXd9WjWw1_wga0JftdtC2-krXg

# ИИ-аннотирование страниц сайта (теги/описание/цели/тезисы/выводы). По умолчанию
# включено; работает только при настроенной LLM-модели (QWEN_API_KEY выше или
# модель в /ai/models + включённый агент «Аннотатор страниц»).
SITEPAGES_ENRICH_ENABLED=true
# Пауза между LLM-запросами при аннотировании (троттлинг лимитов провайдера).
SITEPAGES_ENRICH_DELAY=1s

# Скачивание тел файлов dochub. РАБОЧИЙ способ — сессионная кука браузера
# (DOCHUB_COOKIE): WAF dochub (ServicePipe) блокирует ЛЮБУЮ автоматизацию (curl,
# headless/headful chromedp) на страницах документов — НЕЗАВИСИМО от IP, поэтому
# прокси НЕ помогает (проверено: датацентр/мобильный RU·US/чистый IP — все блок).
# Но с кукой реального браузера, прошедшего WAF, обычный HTTP качает файлы с
# любого IP, без браузера и прокси. Куку проще задавать в админке (/proxy →
# «Кука dochub»); env ниже — фоллбэк. Кука периодически протухает — обновляйте.
DOCHUB_COOKIE=
# PROXY_URL / PROXY6_API_KEY оставлены для совместимости, но для файлов dochub
# НЕ нужны (см. выше). CHROME_PATH нужен лишь старому headless-фоллбэку.
CHROME_PATH=/usr/bin/chromium
PROXY_URL=
PROXY6_API_KEY=
FETCH_LIMIT=0
FETCH_WAIT=7s

MCP_ADDR=:8080
MCP_API_KEY=517a4b18d8701532ce5e9d50671395b8602a9f9e68691f1d
MCP_RATE_LIMIT_RPS=5

ADMIN_ADDR=:8090
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please
