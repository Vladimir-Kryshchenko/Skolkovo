{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"skolkovo\"}[5m])",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"skolkovo\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"skolkovo\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"skolkovo\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      }
    },
    {
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"skolkovo\", status=~\"5..\"}[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "MCP Tool Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(mcp_tool_calls_total[5m])",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "calls/s"
        }
      }
    },
    {
      "title": "MCP Tool Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(mcp_tool_errors_total[5m])",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "errors/s"
        }
      }
    },
    {
      "title": "RAG Search Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_search_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 search",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_embedding_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 embedding",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_qdrant_query_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 qdrant query",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      }
    },
    {
      "title": "Scraping Metrics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(scrape_items_processed_total[5m])",
          "legendFormat": "items processed/s",
          "refId": "A"
        },
        {
          "expr": "scrape_queue_length",
          "legendFormat": "queue length",
          "refId": "B"
        },
        {
          "expr": "rate(scrape_errors_total[5m])",
          "legendFormat": "errors/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Client Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 8,
      "targets": [
        {
          "expr": "rate(client_sessions_active[5m])",
          "legendFormat": "active sessions",
          "refId": "A"
        },
        {
          "expr": "rate(client_messages_sent_total[5m])",
          "legendFormat": "messages/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 9,
      "targets": [
        {
          "expr": "pg_connections_active",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "pg_connections_idle",
          "legendFormat": "idle",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Qdrant Collection Stats",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 10,
      "targets": [
        {
          "expr": "qdrant_collection_vectors_total",
          "legendFormat": "vectors ({{collection}})",
          "refId": "A"
        },
        {
          "expr": "qdrant_collection_points_total",
          "legendFormat": "points ({{collection}})",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Memory & CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 11,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"skolkovo\"}",
          "legendFormat": "RSS memory",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"skolkovo\"}[5m])",
          "legendFormat": "CPU",
          "refId": "B"
        },
        {
          "expr": "go_goroutines{job=\"skolkovo\"}",
          "legendFormat": "goroutines",
          "refId": "C"
        },
        {
          "expr": "go_gc_duration_seconds{quantile=\"0.5\", job=\"skolkovo\"}",
          "legendFormat": "GC p50",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Uptime & Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "targets": [
        {
          "expr": "process_start_time_seconds{job=\"skolkovo\"}",
          "legendFormat": "Start time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "dateTimeAsIso"
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["skolkovo", "production"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Skolkovo Overview",
  "uid": "skolkovo-overview",
  "version": 1
}
